<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#f4f6f8"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="142dp"
        android:background="#1f2d3d"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="10dp">

        <!-- LOGO -->
        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="49dp"
            android:layout_height="53dp"
            android:contentDescription="Logo"
            android:src="@drawable/_000118875" />

        <!-- APP NAME -->

        <!-- NAVIGATION -->
        <!-- PARENT LAYOUT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:background="#1f2d3d"
            android:orientation="vertical">

            <!-- TITLE / LOGO -->
            <TextView
                android:layout_width="332dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:text="Empowering the Nation"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:textStyle="bold" />

            <!-- NAVIGATION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/navHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#3F51B5"
                    android:padding="10dp"
                    android:text="Home"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/navCourses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#3F51B5"
                    android:padding="10dp"
                    android:text="Courses"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/navQuote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#3F51B5"
                    android:padding="10dp"
                    android:text="Get Quote"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/navContact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#3F51B5"
                    android:padding="10dp"
                    android:text="Contact"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="288dp"
            android:layout_height="111dp"
            android:gravity="center"
            android:text="Empowering Skills. Changing Lives."
            android:textColor="#2c3e50"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="183dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="We provide training for domestic workers, gardeners and unemployed individuals."
            android:textColor="#555555"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnQuote"
            android:layout_width="111dp"
            android:layout_height="62dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#FFA550"
            android:text="Get a Quote"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>