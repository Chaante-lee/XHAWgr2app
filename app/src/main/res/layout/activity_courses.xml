<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#f4f6f8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#f4f6f8"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="390dp"
            android:layout_height="114dp"
            android:background="#1f2d3d"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- LOGO -->
            <ImageView
                android:id="@+id/logoImage"
                android:layout_width="49dp"
                android:layout_height="53dp"
                android:contentDescription="Logo"
                android:src="@drawable/_000118875" />

            <!-- TITLE + NAVIGATION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- TITLE / LOGO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Empowering the Nation"
                    android:textColor="#FFFFFF"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <!-- NAVIGATION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/navHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#3F51B5"
                        android:padding="10dp"
                        android:text="Home"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/navQuote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#3F51B5"
                        android:padding="10dp"
                        android:text="Get Quote"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/navContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="#3F51B5"
                        android:padding="10dp"
                        android:text="Contact"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <!-- Page Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Our Courses"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2c3e50"
            android:layout_gravity="center"
            android:paddingBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6 Week short courses"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2c3e50"
            android:layout_gravity="left"
            android:paddingBottom="1dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="left"
            android:paddingBottom="10dp"
            android:text="Fast-track skill development - R750 per course"
            android:textColor="#2c3e50"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Example Course Box 1 -->
        <LinearLayout
            android:id="@+id/courseBox1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/text_border"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Course Title (always visible) -->
            <TextView
                android:id="@+id/courseTitle1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Child Minding"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2c3e50" />

            <!-- Course Description (initially hidden) -->
            <TextView
                android:id="@+id/courseDescription1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Professional childcare training covering child development, safety, nutrition, and age-appropriate activities. Learn to provide quality care in home or childcare center settings. Ideal for those seeking employment as childminders or nannies.."
                android:textSize="14sp"
                android:textColor="#555555"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/courseBox2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/text_border"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Course Title (always visible) -->
            <TextView
                android:id="@+id/courseTitle2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cooking"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2c3e50" />

            <!-- Course Description (initially hidden) -->
            <TextView
                android:id="@+id/courseDescription2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Comprehensive cooking course covering food preparation, nutrition, menu planning, and kitchen safety. Learn essential culinary techniques, hygiene standards, and meal preparation for various dietary needs and occasions."
                android:textSize="14sp"
                android:textColor="#555555"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/courseBox3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/text_border"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Course Title (always visible) -->
            <TextView
                android:id="@+id/courseTitle3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Garden Maintenance"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2c3e50" />

            <!-- Course Description (initially hidden) -->
            <TextView
                android:id="@+id/courseDescription3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Practical garden maintenance training focusing on essential gardening tasks, plant care, pest control, and seasonal maintenance. Learn to maintain gardens professionally and gain skills for employment in garden services."
                android:textSize="14sp"
                android:textColor="#555555"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Add more course boxes similarly -->

    </LinearLayout>
</ScrollView>